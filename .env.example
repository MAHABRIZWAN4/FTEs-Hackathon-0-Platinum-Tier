# Environment Variables Template - Gold Tier
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# ============================================
# LinkedIn Credentials
# ============================================
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# ============================================
# Twitter/X API Credentials (Gold Tier)
# ============================================
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# Get credentials at: https://developer.twitter.com/
# Create an app and generate API keys with Read and Write permissions

# ============================================
# Facebook/Instagram (Meta) API Credentials (Gold Tier)
# ============================================
META_ACCESS_TOKEN=your-long-lived-access-token
FACEBOOK_ACCESS_TOKEN=your-long-lived-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# Get credentials at: https://developers.facebook.com/
# Requirements:
# - Facebook Page (for Facebook posting)
# - Instagram Business account linked to Facebook Page
# - Long-lived access token (60 days)
# - Permissions: pages_manage_posts, instagram_basic, instagram_content_publish

# ============================================
# Email Configuration (SMTP)
# ============================================
EMAIL_ADDRESS=your.email@example.com
EMAIL_PASSWORD=your_app_specific_password_here

# SMTP Server Configuration (optional - defaults to Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# For Gmail: Use App Password instead of regular password
# Generate at: https://myaccount.google.com/apppasswords

# For other providers:
# - Outlook: smtp.office365.com (port 587)
# - Yahoo: smtp.mail.yahoo.com (port 587)
# - Custom SMTP: your.smtp.server.com (port 587 or 465)

# ============================================
# Odoo ERP Integration (Optional)
# ============================================
ODOO_URL=https://your-odoo-instance.odoo.com
ODOO_DB=your-database
ODOO_USERNAME=your-username
ODOO_PASSWORD=your-password

# ============================================
# Optional Configuration
# ============================================
# HEADLESS=true
# LINKEDIN_TIMEOUT=30000

